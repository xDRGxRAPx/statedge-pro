{
  "buildCommand": "pnpm --filter @workspace/statedge run build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/blaze-proxy.js": {
      "maxDuration": 10
    }
  }
}
